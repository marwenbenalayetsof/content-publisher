# Environment variables for Content Publisher
# Copy this file to .env and fill in your credentials

# Flask
SECRET_KEY=change-me-to-a-random-string
FLASK_DEBUG=True

# YouTube / Google OAuth
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REDIRECT_URI=http://localhost:5000/auth/youtube/callback

# TikTok OAuth
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_REDIRECT_URI=http://localhost:5000/auth/tiktok/callback

# Facebook / Instagram OAuth
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_REDIRECT_URI=http://localhost:5000/auth/facebook/callback
